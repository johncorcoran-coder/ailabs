generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  createdAt     DateTime       @default(now())
  wpConnections WPConnection[]
  audits        Audit[]
  tokenBalance  TokenBalance?
  transactions  Transaction[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model WPConnection {
  id               String   @id @default(cuid())
  userId           String
  siteUrl          String
  wpUsername       String
  wpAppPassword    String   // encrypted at rest
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  audits           Audit[]
  schedules        AuditSchedule[]

  @@index([userId])
}

model Audit {
  id                     String       @id @default(cuid())
  userId                 String
  wpConnectionId         String
  siteUrl                String
  status                 String       @default("pending") // pending, crawling, analyzing, complete, failed
  totalPagesCrawled      Int          @default(0)
  totalIssuesFound       Int          @default(0)
  estimatedTokens        Int          @default(0)
  estimatedCostUsd       Float        @default(0)
  agencyComparisonCostUsd Float       @default(0)
  healthScore            Int          @default(0)
  // Progress tracking (Phase 3)
  progressMessage        String?      // Human-readable progress message
  progressPercent        Int          @default(0) // 0-100
  totalUrlsDiscovered    Int          @default(0) // URLs found during discovery
  pagesCrawledSoFar      Int          @default(0) // Pages crawled so far (live counter)
  pagesAnalyzedSoFar     Int          @default(0) // Pages analyzed so far (live counter)
  errorDetails           String?      @db.Text // Detailed error info for failed audits
  // Phase 4: before/after tracking
  previousAuditId        String?      // Link to the prior audit for this site
  scheduledBy            String?      // AuditSchedule id if triggered by schedule
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  user                   User         @relation(fields: [userId], references: [id])
  wpConnection           WPConnection @relation(fields: [wpConnectionId], references: [id])
  issues                 AuditIssue[]
  crawledPages           CrawledPageData[]

  @@index([userId])
  @@index([wpConnectionId, createdAt])
}

model CrawledPageData {
  id          String @id @default(cuid())
  auditId     String
  url         String
  rawData     Json   // stores the full CrawledPage object
  audit       Audit  @relation(fields: [auditId], references: [id])

  @@index([auditId])
}

model AuditIssue {
  id                String   @id @default(cuid())
  auditId           String
  pageUrl           String
  issueType         String
  severity          String   // critical, high, medium, low
  priorityRank      Int
  currentValue      String   @db.Text
  suggestedValue    String   @db.Text
  userModifiedValue String?  @db.Text
  status            String   @default("pending") // pending, approved, applied, skipped
  appliedAt         DateTime?
  audit             Audit    @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([auditId, severity])
}

model TokenBalance {
  id             String @id @default(cuid())
  userId         String @unique
  balanceTokens  Int    @default(0)
  totalPurchased Float  @default(0)
  user           User   @relation(fields: [userId], references: [id])
}

model Transaction {
  id                    String   @id @default(cuid())
  userId                String
  stripePaymentIntentId String
  amountUsd             Float
  tokensCredited        Int
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Phase 4: Scheduled re-audits
model AuditSchedule {
  id               String       @id @default(cuid())
  wpConnectionId   String
  userId           String
  frequency        String       @default("monthly") // monthly, weekly, biweekly
  enabled          Boolean      @default(true)
  lastRunAt        DateTime?
  nextRunAt        DateTime?
  createdAt        DateTime     @default(now())
  wpConnection     WPConnection @relation(fields: [wpConnectionId], references: [id])

  @@unique([wpConnectionId])
  @@index([enabled, nextRunAt])
}
